DATABASE_URL="postgresql://postgres:sankeerth@localhost:5432/pharma_b2b?schema=public"
JWT_SECRET="pharma-b2b-super-secret-jwt-key-2024"
PORT=3001
NODE_ENV=development

# ── Payment Reminder Settings ───────────────────────────────────────────────
# Channel: WHATSAPP | SMS | IN_APP (default: IN_APP — safe without Twilio creds)
REMINDER_CHANNEL=IN_APP
# Minimum outstanding balance (₹) to trigger a reminder
MIN_OVERDUE_AMOUNT=500
# Cron schedule (UTC). Default = 03:30 UTC = 09:00 AM IST
REMINDER_CRON_SCHEDULE="30 3 * * *"

# ── Twilio (required only when REMINDER_CHANNEL=WHATSAPP or SMS) ────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_SMS_FROM=+14155238886
