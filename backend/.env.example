# Database (local PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/pharma_b2b?schema=public"

# JWT
JWT_SECRET="pharma_b2b_super_secret_jwt_key_change_this_in_production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
CLIENT_URL="http://localhost:5173"
# Optional comma-separated extra CORS origins for production deploys
# CLIENT_URLS="https://pharmahead.app,https://app.pharmahead.app"

# ── Email Verification + SMTP (Zoho) ───────────────────────────────────────
# URL used in verification links. Use your live frontend origin in production.
EMAIL_VERIFICATION_FRONTEND_URL="https://pharmahead.app"
# Verification link TTL in hours
EMAIL_VERIFICATION_TTL_HOURS=24

# Zoho SMTP (sender: noreply@pharmahead.app)
SMTP_HOST="smtp.zoho.in"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="noreply@pharmahead.app"
SMTP_PASS="your_zoho_app_password"
SMTP_FROM="Pharma Head <noreply@pharmahead.app>"
# Optional hardening for production mail timeout issues
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
# Optional fallback route if primary SMTP host/port is blocked in hosting network
# SMTP_FALLBACK_HOSTS="smtp.zoho.com"
# SMTP_FALLBACK_PORTS="587"

# Firebase Admin (required for phone verification gate on wholesaler registrations)
# Use Firebase service account values. Keep PRIVATE_KEY quoted with escaped newlines.
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-firebase-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Payment Reminder Settings ───────────────────────────────────────────────
# Channel: WHATSAPP | SMS | IN_APP (default: IN_APP — no Twilio needed)
REMINDER_CHANNEL=IN_APP
# Minimum outstanding balance (₹) before a reminder is sent
MIN_OVERDUE_AMOUNT=500
# Cron schedule in UTC. Default fires at 09:00 AM IST (03:30 UTC)
REMINDER_CRON_SCHEDULE="30 3 * * *"

# ── Twilio (required only when REMINDER_CHANNEL=WHATSAPP or SMS) ────────────
# Sign up at https://www.twilio.com/ and enable WhatsApp Sandbox or a verified number
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_SMS_FROM=+14155238886
