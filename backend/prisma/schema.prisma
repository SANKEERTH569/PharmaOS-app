// This is your Prisma schema file for Pharma B2B Dashboard
// Learn more at: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MainWholesaler {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  name          String
  phone         String   @unique
  address       String?
  gstin         String?
  dl_number     String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  supply_orders SupplyOrder[]
  medicines     MainWholesalerMedicine[]
  schemes       MainWholesalerScheme[]
  connections   MainWholesalerConnection[]
  ledger_entries MainWholesalerLedgerEntry[]
  payments      MainWholesalerPayment[]
}

model Wholesaler {
  id            String   @id @default(cuid())
  username      String?  @unique
  password_hash String?
  name          String
  phone         String   @unique
  address       String?
  gstin         String?
  dl_number     String?
  email         String?
  bank_name     String?
  bank_account  String?
  ifsc          String?
  upi_id        String?
  plan          String   @default("starter") // starter | growth | pro | enterprise
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  retailers        Retailer[]
  medicines        Medicine[]
  orders           Order[]
  ledger_entries   LedgerEntry[]
  payments         Payment[]
  notifications    Notification[]
  retailer_agencies RetailerAgency[]
  return_requests   ReturnRequest[]
  plan_requests     PlanRequest[]
  schemes           Scheme[]
  purchase_orders   PurchaseOrder[]
  grns              GoodsReceiptNote[]
  supply_orders     SupplyOrder[]
  stock_complaints  StockComplaint[]

  mw_connections    MainWholesalerConnection[]
  mw_ledger_entries MainWholesalerLedgerEntry[]
  mw_payments       MainWholesalerPayment[]
  reminder_logs     ReminderLog[]

  // Sales Force Management
  salesmen          Salesman[]
  beat_routes       BeatRoute[]
  call_reports      DailyCallReport[]
  salesman_targets  SalesmanTarget[]
  salesman_links    SalesmanWholesalerLink[]
}

model Retailer {
  id                String     @id @default(cuid())
  wholesaler_id     String?
  wholesaler        Wholesaler? @relation(fields: [wholesaler_id], references: [id])
  name              String
  shop_name         String
  phone             String     @unique
  password_hash     String?
  address           String?
  gstin             String?
  dl_number         String?
  credit_limit      Float      @default(50000)
  current_balance   Float      @default(0)
  is_active         Boolean    @default(true)
  is_self_registered Boolean   @default(false)
  last_payment_date DateTime?
  created_at        DateTime   @default(now())

  orders         Order[]
  ledger_entries LedgerEntry[]
  payments       Payment[]
  notifications    Notification[]
  agencies         RetailerAgency[]
  return_requests  ReturnRequest[]
  stock_complaints StockComplaint[]
  reminder_logs    ReminderLog[]

  // Sales Force Management
  beat_assignments BeatRetailer[]
  call_reports     DailyCallReport[]
}

model RetailerAgency {
  id            String     @id @default(cuid())
  retailer_id   String
  wholesaler_id String
  retailer      Retailer   @relation(fields: [retailer_id], references: [id], onDelete: Cascade)
  wholesaler    Wholesaler @relation(fields: [wholesaler_id], references: [id], onDelete: Cascade)
  is_primary    Boolean    @default(false)
  status        String     @default("ACTIVE") // PENDING | ACTIVE | BLOCKED
  created_at    DateTime   @default(now())

  @@unique([retailer_id, wholesaler_id])
}

model Medicine {
  id                String      @id @default(cuid())
  wholesaler_id     String?     // null = catalog entry; non-null = wholesaler inventory item
  wholesaler        Wholesaler? @relation(fields: [wholesaler_id], references: [id])
  name              String
  salt              String?
  composition2      String?
  brand             String?
  unit              String     @default("strip")
  pack_size         String?
  mrp               Float
  price             Float
  gst_rate          Float      @default(12)
  hsn_code          String     @default("3004")
  stock_qty         Int        @default(0)
  expiry_date       DateTime?
  therapeutic_class String?
  side_effects      String?
  uses              String?
  is_discontinued   Boolean    @default(false)
  is_active         Boolean    @default(true)
  rack_location     String?    // Pro feature: physical rack/shelf location (e.g. "Rack A - Shelf 3")
  created_at        DateTime   @default(now())

  order_items OrderItem[]
  batches     MedicineBatch[]
  schemes     Scheme[]
  grn_items   GRNItem[]
}

enum SchemeType {
  BOGO
  HALF_SCHEME
  CASH_DISCOUNT
}

model Scheme {
  id             String      @id @default(cuid())
  wholesaler_id  String
  wholesaler     Wholesaler  @relation(fields: [wholesaler_id], references: [id])
  name           String
  type           SchemeType
  min_qty        Int?
  free_qty       Float?
  discount_pct   Float?
  medicine_id    String?
  medicine       Medicine?   @relation(fields: [medicine_id], references: [id])
  is_active      Boolean     @default(true)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
}

model MedicineBatch {
  id          String   @id @default(cuid())
  medicine_id String
  medicine    Medicine @relation(fields: [medicine_id], references: [id], onDelete: Cascade)
  batch_no    String
  expiry_date DateTime
  stock_qty   Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([medicine_id, batch_no])
}

model Order {
  id            String      @id @default(cuid())
  invoice_no    String?
  wholesaler_id String
  retailer_id   String
  wholesaler    Wholesaler  @relation(fields: [wholesaler_id], references: [id])
  retailer      Retailer    @relation(fields: [retailer_id], references: [id])
  salesman_id   String?
  salesman      Salesman?   @relation(fields: [salesman_id], references: [id])
  retailer_name String
  status        OrderStatus @default(PENDING)
  sub_total     Float
  tax_total     Float
  total_amount  Float
  payment_terms String?
  notes         String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  items          OrderItem[]
  ledger_entries LedgerEntry[]
}

enum OrderStatus {
  PENDING_RETAILER
  PENDING
  ACCEPTED
  DISPATCHED
  DELIVERED
  REJECTED
  CANCELLED
}

model OrderItem {
  id               String   @id @default(cuid())
  order_id         String
  medicine_id      String
  order            Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  medicine         Medicine @relation(fields: [medicine_id], references: [id])
  medicine_name    String
  qty              Int
  mrp              Float
  unit_price       Float
  discount_percent Float    @default(0)
  discount_amount  Float    @default(0)
  total_price      Float
  hsn_code         String?
  gst_rate         Float    @default(12)
  taxable_value    Float
  tax_amount       Float
}

model LedgerEntry {
  id            String      @id @default(cuid())
  wholesaler_id String
  retailer_id   String
  wholesaler    Wholesaler  @relation(fields: [wholesaler_id], references: [id])
  retailer      Retailer    @relation(fields: [retailer_id], references: [id])
  type          LedgerType
  amount        Float
  balance_after Float
  reference_id  String?
  description   String
  order_id      String?
  order         Order?      @relation(fields: [order_id], references: [id])
  created_at    DateTime    @default(now())
}

enum LedgerType {
  DEBIT
  CREDIT
}

model Payment {
  id            String        @id @default(cuid())
  wholesaler_id String
  retailer_id   String
  wholesaler    Wholesaler    @relation(fields: [wholesaler_id], references: [id])
  retailer      Retailer      @relation(fields: [retailer_id], references: [id])
  retailer_name String
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(COMPLETED)
  notes         String?
  razorpay_id   String?
  created_at    DateTime      @default(now())
}

enum PaymentMethod {
  CASH
  UPI
  CHEQUE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Notification {
  id            String           @id @default(cuid())
  wholesaler_id String
  wholesaler    Wholesaler       @relation(fields: [wholesaler_id], references: [id])
  retailer_id   String?
  retailer      Retailer?        @relation(fields: [retailer_id], references: [id])
  type          NotificationType
  title         String
  body          String
  is_read       Boolean          @default(false)
  created_at    DateTime         @default(now())
}

enum NotificationType {
  NEW_ORDER
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  CREDIT_LIMIT_ALERT
  OVERDUE_REMINDER
  ORDER_STATUS_CHANGED
  AGENCY_ACCEPTED
  AGENCY_REJECTED
}

enum ReturnReason {
  EXPIRED
  DAMAGED
  MISSING
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

model ReturnRequest {
  id              String       @id @default(cuid())
  wholesaler_id   String
  retailer_id     String
  wholesaler      Wholesaler   @relation(fields: [wholesaler_id], references: [id])
  retailer        Retailer     @relation(fields: [retailer_id], references: [id])
  reason          ReturnReason
  status          ReturnStatus @default(PENDING)
  notes           String?
  rejection_note  String?
  total_amount    Float
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  items           ReturnItem[]
}

model ReturnItem {
  id              String        @id @default(cuid())
  return_id       String
  return_request  ReturnRequest @relation(fields: [return_id], references: [id], onDelete: Cascade)
  medicine_name   String
  batch_no        String?
  expiry_date     String?
  qty             Int
  unit_price      Float
  total_price     Float
  reason_detail   String?
}

enum ComplaintType {
  SHORT_DELIVERY
  WRONG_ITEM
  MISSING_ITEM
}

enum ComplaintStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model StockComplaint {
  id              String          @id @default(cuid())
  wholesaler_id   String
  retailer_id     String
  wholesaler      Wholesaler      @relation(fields: [wholesaler_id], references: [id])
  retailer        Retailer        @relation(fields: [retailer_id], references: [id])
  order_id        String?
  complaint_type  ComplaintType
  status          ComplaintStatus @default(OPEN)
  notes           String?
  resolution_note String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  items           StockComplaintItem[]
}

model StockComplaintItem {
  id            String         @id @default(cuid())
  complaint_id  String
  complaint     StockComplaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  medicine_name String
  ordered_qty   Int
  received_qty  Int
  unit_price    Float
}

model Admin {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  name          String
  email         String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
}

model PlanRequest {
  id              String   @id @default(cuid())
  wholesaler_id   String
  wholesaler      Wholesaler @relation(fields: [wholesaler_id], references: [id])
  current_plan    String
  requested_plan  String
  status          String   @default("PENDING")    // PENDING | APPROVED | REJECTED
  coupon_code     String?
  discount_amount Float    @default(0)
  final_amount    Float    @default(0)
  admin_note      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discount_type   String   @default("PERCENTAGE")  // PERCENTAGE | FLAT
  discount_value  Float
  max_uses        Int      @default(0)              // 0 = unlimited
  used_count      Int      @default(0)
  is_active       Boolean  @default(true)
  valid_plans     String?                            // comma-separated: "growth,pro" or null = all
  expires_at      DateTime?
  created_at      DateTime @default(now())
}

// ── Purchase Orders & GRN ──────────────────────────────────────────────────

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id                 String    @id @default(cuid())
  po_number          String
  wholesaler_id      String
  wholesaler         Wholesaler @relation(fields: [wholesaler_id], references: [id])
  main_wholesaler_id String?   // optional link to a registered MainWholesaler
  supplier_name      String
  supplier_phone     String?
  supplier_gstin     String?
  status             POStatus  @default(DRAFT)
  notes              String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  items        POItem[]
  grns         GoodsReceiptNote[]
  supply_order SupplyOrder?

  @@unique([wholesaler_id, po_number])
}

model POItem {
  id            String        @id @default(cuid())
  po_id         String
  po            PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: Cascade)
  medicine_id   String?
  medicine_name String
  qty_ordered   Int
  qty_received  Int           @default(0)
  unit_cost     Float

  @@index([po_id])
}

model GoodsReceiptNote {
  id            String         @id @default(cuid())
  grn_number    String
  wholesaler_id String
  wholesaler    Wholesaler     @relation(fields: [wholesaler_id], references: [id])
  po_id         String?
  po            PurchaseOrder? @relation(fields: [po_id], references: [id])
  supplier_name String
  notes         String?
  created_at    DateTime       @default(now())

  items GRNItem[]

  @@unique([wholesaler_id, grn_number])
}

model GRNItem {
  id            String           @id @default(cuid())
  grn_id        String
  grn           GoodsReceiptNote @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  medicine_id   String
  medicine      Medicine         @relation(fields: [medicine_id], references: [id])
  medicine_name String
  batch_no      String
  expiry_date   DateTime
  qty_received  Int
  unit_cost     Float

  @@index([grn_id])
}

// ── Supply Orders (Sub-Wholesaler → Main Wholesaler) ──────────────────────

enum SupplyOrderStatus {
  PENDING
  ACCEPTED
  DISPATCHED
  DELIVERED
  CANCELLED
}

model SupplyOrder {
  id                 String            @id @default(cuid())
  so_number          String
  wholesaler_id      String
  wholesaler         Wholesaler        @relation(fields: [wholesaler_id], references: [id])
  main_wholesaler_id String
  main_wholesaler    MainWholesaler    @relation(fields: [main_wholesaler_id], references: [id])
  purchase_order_id  String?           @unique
  purchase_order     PurchaseOrder?    @relation(fields: [purchase_order_id], references: [id])
  status             SupplyOrderStatus @default(PENDING)
  notes              String?
  total_amount       Float             @default(0)
  dispatch_date      DateTime?
  delivered_date     DateTime?
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  items SupplyOrderItem[]

  @@unique([main_wholesaler_id, so_number])
}

model SupplyOrderItem {
  id            String      @id @default(cuid())
  so_id         String
  supply_order  SupplyOrder @relation(fields: [so_id], references: [id], onDelete: Cascade)
  medicine_name String
  qty_ordered   Int
  unit_cost     Float
  total_price   Float

  @@index([so_id])
}

// ── Main Wholesaler Catalog ────────────────────────────────────────────────
model MainWholesalerMedicine {
  id                 String         @id @default(cuid())
  main_wholesaler_id String
  main_wholesaler    MainWholesaler @relation(fields: [main_wholesaler_id], references: [id], onDelete: Cascade)
  medicine_name      String
  brand              String?
  mrp                Float?
  price              Float          // B2B selling price
  stock_qty          Int?           // Current stock available
  expiry_date        DateTime?      // Nearest expiry date for current batch
  gst_rate           Float          @default(12)
  hsn_code           String         @default("3004")
  unit_type          String         @default("strip")
  is_active          Boolean        @default(true)
  created_at         DateTime       @default(now())

  schemes            MainWholesalerScheme[]

  @@unique([main_wholesaler_id, medicine_name])
}

model MainWholesalerScheme {
  id                 String                 @id @default(cuid())
  main_wholesaler_id String
  main_wholesaler    MainWholesaler         @relation(fields: [main_wholesaler_id], references: [id])
  name               String
  type               SchemeType
  min_qty            Int?
  free_qty           Float?
  discount_pct       Float?
  medicine_id        String?
  medicine           MainWholesalerMedicine? @relation(fields: [medicine_id], references: [id])
  is_active          Boolean                @default(true)
  created_at         DateTime               @default(now())
  updated_at         DateTime               @updatedAt
}

// ── Main Wholesaler Finance (Ledger & Payments) ────────────────────────────

model MainWholesalerConnection {
  id                 String         @id @default(cuid())
  main_wholesaler_id String
  wholesaler_id      String
  main_wholesaler    MainWholesaler @relation(fields: [main_wholesaler_id], references: [id])
  wholesaler         Wholesaler     @relation(fields: [wholesaler_id], references: [id])
  credit_limit       Float          @default(500000)
  current_balance    Float          @default(0)
  status             String         @default("ACTIVE") // PENDING | ACTIVE | BLOCKED
  created_at         DateTime       @default(now())

  @@unique([main_wholesaler_id, wholesaler_id])
}

model MainWholesalerLedgerEntry {
  id                 String         @id @default(cuid())
  main_wholesaler_id String
  wholesaler_id      String
  main_wholesaler    MainWholesaler @relation(fields: [main_wholesaler_id], references: [id])
  wholesaler         Wholesaler     @relation(fields: [wholesaler_id], references: [id])
  type               LedgerType
  amount             Float
  balance_after      Float
  reference_id       String?
  description        String
  created_at         DateTime       @default(now())
}

model MainWholesalerPayment {
  id                 String         @id @default(cuid())
  main_wholesaler_id String
  wholesaler_id      String
  main_wholesaler    MainWholesaler @relation(fields: [main_wholesaler_id], references: [id])
  wholesaler         Wholesaler     @relation(fields: [wholesaler_id], references: [id])
  wholesaler_name    String
  amount             Float
  method             PaymentMethod
  status             PaymentStatus  @default(COMPLETED)
  notes              String?
  razorpay_id        String?
  created_at         DateTime       @default(now())
}

// ── Payment Reminder Logs ──────────────────────────────────────────────────

model ReminderLog {
  id            String     @id @default(cuid())
  wholesaler_id String
  retailer_id   String
  wholesaler    Wholesaler @relation(fields: [wholesaler_id], references: [id])
  retailer      Retailer   @relation(fields: [retailer_id], references: [id])
  channel       String     // WHATSAPP | SMS | IN_APP
  status        String     // SENT | FAILED | SKIPPED
  amount_due    Float
  phone         String
  error         String?
  sent_at       DateTime   @default(now())

  @@index([wholesaler_id, sent_at])
  @@index([retailer_id, sent_at])
}

// ── Sales Rep & Field Force Management ────────────────────────────────────

model Salesman {
  id            String     @id @default(cuid())
  wholesaler_id String?
  wholesaler    Wholesaler? @relation(fields: [wholesaler_id], references: [id])
  name          String
  phone         String     @unique
  username      String     @unique
  password_hash String
  company_name  String?    // Pharma company they represent
  employee_id   String?    // Company employee/MR code
  territory     String?    // e.g., "Hyderabad North"
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())

  beat_routes  BeatRoute[]
  call_reports DailyCallReport[]
  targets      SalesmanTarget[]
  orders       Order[]
  links        SalesmanWholesalerLink[]
}

model SalesmanWholesalerLink {
  id            String     @id @default(cuid())
  salesman_id   String
  salesman      Salesman   @relation(fields: [salesman_id], references: [id])
  wholesaler_id String
  wholesaler    Wholesaler @relation(fields: [wholesaler_id], references: [id])
  status        LinkStatus @default(PENDING)
  message       String?    // Optional message from salesman
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@unique([salesman_id, wholesaler_id])
}

enum LinkStatus {
  PENDING
  APPROVED
  REJECTED
}

model BeatRoute {
  id            String     @id @default(cuid())
  wholesaler_id String
  wholesaler    Wholesaler @relation(fields: [wholesaler_id], references: [id])
  salesman_id   String?
  salesman      Salesman?  @relation(fields: [salesman_id], references: [id])
  name          String
  description   String?
  created_at    DateTime   @default(now())

  retailers BeatRetailer[]
}

model BeatRetailer {
  id          String    @id @default(cuid())
  beat_id     String
  beat        BeatRoute @relation(fields: [beat_id], references: [id], onDelete: Cascade)
  retailer_id String
  retailer    Retailer  @relation(fields: [retailer_id], references: [id])

  @@unique([beat_id, retailer_id])
}

enum CallOutcome {
  ORDER_TAKEN
  NO_ORDER
  PAYMENT_COLLECTED
  NOT_VISITED
}

model DailyCallReport {
  id             String      @id @default(cuid())
  wholesaler_id  String
  wholesaler     Wholesaler  @relation(fields: [wholesaler_id], references: [id])
  salesman_id    String
  salesman       Salesman    @relation(fields: [salesman_id], references: [id])
  retailer_id    String
  retailer       Retailer    @relation(fields: [retailer_id], references: [id])
  visit_date     DateTime    @default(now())
  outcome        CallOutcome
  order_id       String?
  payment_amount  Float?
  payment_method  String?   // CASH | UPI | CHEQUE | BANK_TRANSFER
  notes          String?
  lat            Float?
  lng            Float?
  created_at     DateTime    @default(now())

  @@index([wholesaler_id, visit_date])
  @@index([salesman_id, visit_date])
}

model SalesmanTarget {
  id                    String     @id @default(cuid())
  wholesaler_id         String
  wholesaler            Wholesaler @relation(fields: [wholesaler_id], references: [id])
  salesman_id           String
  salesman              Salesman   @relation(fields: [salesman_id], references: [id])
  month                 Int
  year                  Int
  order_target          Float      @default(0)
  collection_target     Float      @default(0)
  new_retailers_target  Int        @default(0)
  created_at            DateTime   @default(now())

  @@unique([salesman_id, month, year])
}
